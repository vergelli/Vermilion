<GuiXml>
  <Controls>

    <!--
      Vermilion settings — a movable window with the three v0.1 sliders
      (SPEC §2.1): Sampling Rate, Time Window, Viewport Alpha. Verdant's
      bar-related sliders (refresh rate, heal/shield windows) and the profile
      dropdown are dropped. Position persisted in SavedVars.settings.{x,y}.
    -->
    <TopLevelControl name="VermilionSettingsPanel"
                     hidden="true"
                     clampedToScreen="true"
                     movable="true"
                     mouseEnabled="true">

      <Dimensions x="280" y="290"/>

      <OnMoveStop>Vermilion.Settings.on_move_stop()</OnMoveStop>

      <Controls>

        <Backdrop name="$(parent)Bg">
          <AnchorFill/>
          <Edge file="EsoUI/Art/Tooltips/UI-Border.dds"
                edgeFileWidth="128" edgeFileHeight="16" edgeSize="6"/>
          <Center file="EsoUI/Art/Tooltips/UI-TooltipCenter.dds"/>
          <Insets left="6" top="6" right="-6" bottom="-6"/>
        </Backdrop>

        <!-- ── title bar ───────────────────────────────────────────────── -->
        <!-- Brand mark: small logo left of the window title (identity). -->
        <Texture name="$(parent)BrandLogo" textureFile="Vermilion/assets/logo.dds">
          <Anchor point="TOPLEFT" offsetX="12" offsetY="8"/>
          <Dimensions x="24" y="24"/>
        </Texture>

        <Label name="$(parent)WindowTitle"
               font="ZoFontWindowTitle"
               horizontalAlignment="LEFT"
               verticalAlignment="CENTER">
          <Anchor point="TOPLEFT" offsetX="42" offsetY="10"/>
          <Dimensions y="18"/>
        </Label>

        <Button name="$(parent)CloseBtn" mouseEnabled="true"
                mouseOverBlendMode="ADD" inherits="ZO_ButtonBehaviorClickSound">
          <Anchor point="TOPRIGHT" offsetX="-8" offsetY="8"/>
          <Dimensions x="16" y="16"/>
          <Textures normal="EsoUI/Art/Buttons/decline_up.dds"
                    pressed="EsoUI/Art/Buttons/decline_down.dds"
                    mouseOver="EsoUI/Art/Buttons/decline_over.dds"/>
          <OnClicked>Vermilion.Settings.toggle()</OnClicked>
        </Button>

        <!-- ── Row 1: Sampling Rate ────────────────────────────────────── -->
        <Label name="$(parent)SampleTitle"
               font="ZoFontGameSmall"
               horizontalAlignment="LEFT"
               verticalAlignment="CENTER">
          <Anchor point="TOPLEFT" offsetX="14" offsetY="48"/>
          <Dimensions x="160" y="12"/>
        </Label>

        <Label name="$(parent)SampleLabel"
               font="ZoFontGameSmall"
               horizontalAlignment="RIGHT"
               verticalAlignment="CENTER">
          <Anchor point="TOPRIGHT" offsetX="-14" offsetY="48"/>
          <Dimensions x="80" y="12"/>
        </Label>

        <Control name="$(parent)SliderTrackSample" mouseEnabled="true">
          <Anchor point="TOPLEFT"  offsetX="14"  offsetY="63"/>
          <Anchor point="TOPRIGHT" offsetX="-14" offsetY="63"/>
          <Dimensions y="14"/>
          <OnMouseUp>Vermilion.Settings.on_sample_track_click(self)</OnMouseUp>
        </Control>

        <!-- ── Row 2: Time Window ──────────────────────────────────────── -->
        <Label name="$(parent)TWindowTitle"
               font="ZoFontGameSmall"
               horizontalAlignment="LEFT"
               verticalAlignment="CENTER">
          <Anchor point="TOPLEFT" offsetX="14" offsetY="86"/>
          <Dimensions x="160" y="12"/>
        </Label>

        <Label name="$(parent)TWindowLabel"
               font="ZoFontGameSmall"
               horizontalAlignment="RIGHT"
               verticalAlignment="CENTER">
          <Anchor point="TOPRIGHT" offsetX="-14" offsetY="86"/>
          <Dimensions x="80" y="12"/>
        </Label>

        <Control name="$(parent)SliderTrackTWindow" mouseEnabled="true">
          <Anchor point="TOPLEFT"  offsetX="14"  offsetY="101"/>
          <Anchor point="TOPRIGHT" offsetX="-14" offsetY="101"/>
          <Dimensions y="14"/>
          <OnMouseUp>Vermilion.Settings.on_twindow_track_click(self)</OnMouseUp>
        </Control>

        <!-- ── Row 3: Viewport Alpha ───────────────────────────────────── -->
        <Label name="$(parent)VPAlphaTitle"
               font="ZoFontGameSmall"
               horizontalAlignment="LEFT"
               verticalAlignment="CENTER">
          <Anchor point="TOPLEFT" offsetX="14" offsetY="124"/>
          <Dimensions x="160" y="12"/>
        </Label>

        <Label name="$(parent)VPAlphaLabel"
               font="ZoFontGameSmall"
               horizontalAlignment="RIGHT"
               verticalAlignment="CENTER">
          <Anchor point="TOPRIGHT" offsetX="-14" offsetY="124"/>
          <Dimensions x="80" y="12"/>
        </Label>

        <Control name="$(parent)SliderTrackVPAlpha" mouseEnabled="true">
          <Anchor point="TOPLEFT"  offsetX="14"  offsetY="139"/>
          <Anchor point="TOPRIGHT" offsetX="-14" offsetY="139"/>
          <Dimensions y="14"/>
          <OnMouseUp>Vermilion.Settings.on_vpalpha_track_click(self)</OnMouseUp>
        </Control>

        <!-- ── Unknown Contributions entry (opens the assignment window) ── -->
        <Button name="$(parent)UnknownBtn" mouseEnabled="true"
                mouseOverBlendMode="ADD" inherits="ZO_ButtonBehaviorClickSound">
          <Anchor point="BOTTOMLEFT" offsetX="14" offsetY="-78"/>
          <Dimensions x="28" y="28"/>
          <Textures normal="EsoUI/Art/Dye/dyes_toolIcon_fill_up.dds"
                    pressed="EsoUI/Art/Dye/dyes_toolIcon_fill_down.dds"
                    mouseOver="EsoUI/Art/Dye/dyes_toolIcon_fill_over.dds"/>
          <OnClicked>Vermilion.Settings.on_unknown_click()</OnClicked>
        </Button>

        <Label name="$(parent)UnknownLabel"
               font="ZoFontGameSmall"
               horizontalAlignment="LEFT"
               verticalAlignment="CENTER"
               mouseEnabled="true">
          <Anchor point="LEFT" relativeTo="$(parent)UnknownBtn" relativePoint="RIGHT" offsetX="10" offsetY="0"/>
          <Dimensions x="210" y="28"/>
          <OnMouseUp>Vermilion.Settings.on_unknown_click()</OnMouseUp>
        </Label>

        <!-- ── Logo visibility toggle ──────────────────────────────────── -->
        <Button name="$(parent)LogoBtn"
                mouseEnabled="true"
                font="ZoFontGameSmall"
                inherits="ZO_DefaultButton">
          <Anchor point="BOTTOMLEFT"  offsetX="14"  offsetY="-44"/>
          <Anchor point="BOTTOMRIGHT" offsetX="-14" offsetY="-44"/>
          <Dimensions y="22"/>
          <OnClicked>Vermilion.Settings.on_logo_click()</OnClicked>
        </Button>

        <!-- ── Reset to Defaults button ────────────────────────────────── -->
        <Button name="$(parent)ResetBtn"
                mouseEnabled="true"
                font="ZoFontGameSmall"
                inherits="ZO_DefaultButton">
          <Anchor point="BOTTOMLEFT"  offsetX="14"  offsetY="-12"/>
          <Anchor point="BOTTOMRIGHT" offsetX="-14" offsetY="-12"/>
          <Dimensions y="22"/>
          <OnClicked>Vermilion.Settings.on_reset_click()</OnClicked>
        </Button>

      </Controls>
    </TopLevelControl>

  </Controls>
</GuiXml>
